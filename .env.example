# =============================================================
# LMS Chat Server — Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================

# ─────────────────────────────────────────────────────────────
# Server
# ─────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3001

# ─────────────────────────────────────────────────────────────
# CORS — comma-separated list of allowed origins
# React Native uses capacitor/expo URLs; web uses your domain
# ─────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://your-app.com,https://admin.your-app.com

# ─────────────────────────────────────────────────────────────
# MySQL — shared database with Laravel
# READ:  personal_access_tokens, users, chat_groups,
#        chat_group_members, chat_message_attachments
# WRITE: chat_messages, chat_message_reactions,
#        chat_message_reads, chat_group_members (mute/read)
# ─────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=lms_db
DB_USERNAME=lms_user
DB_PASSWORD=secret
DB_POOL_MIN=2
DB_POOL_MAX=20

# ─────────────────────────────────────────────────────────────
# Redis — used for:
#   • Socket.IO pub/sub adapter (horizontal scaling)
#   • Sanctum token cache
#   • Membership + role cache
#   • Presence tracking (online users per group)
#   • Typing indicators (auto-expire)
#   • Rate limiting counters
#   • User socket ID index (multi-tab support)
# ─────────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ─────────────────────────────────────────────────────────────
# Cache TTLs (in seconds)
# ─────────────────────────────────────────────────────────────

# How long to cache a validated Sanctum token in Redis
# After expiry, the next event re-validates against MySQL
TOKEN_CACHE_TTL=300

# How long a user's presence entry survives without a heartbeat
# Client should send 'heartbeat' event every 60s
PRESENCE_TTL=120

# How long a typing indicator stays alive without a new typing:start
# Prevents "typing forever" if client disconnects without typing:stop
TYPING_TTL=5

# How long to cache a user's group membership + role in Redis
# Invalidate manually via Redis::del() from Laravel when membership changes
MEMBERSHIP_CACHE_TTL=600

# ─────────────────────────────────────────────────────────────
# Rate Limiting (students only — teachers/admins are exempt)
# ─────────────────────────────────────────────────────────────

# Max messages a student can send per group per window
RATE_LIMIT_MESSAGES=30

# Sliding window duration in seconds
RATE_LIMIT_WINDOW_SECONDS=60
